# =============================================================================
# Homes by Fattori — Environment Variables
# Copy this file to ".env.local" and fill in the real values.
# =============================================================================

# Resend API key — required for the contact form to send email.
# Get a free key at https://resend.com/api-keys (free tier: 3,000 emails/month)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The address that receives new commission enquiries.
# In production this should be a verified address/domain on Resend.
CONTACT_TO_EMAIL=hello@homesbyfattori.com

# The "from" address shown on outgoing mail.
# Until you verify your own domain on Resend, use the sandbox sender below:
#   onboarding@resend.dev
# After verifying homesbyfattori.com, switch to e.g.:
#   Homes by Fattori <hello@homesbyfattori.com>
CONTACT_FROM_EMAIL=Homes by Fattori <onboarding@resend.dev>

# Google Analytics 4 measurement ID (optional).
# Leave blank to disable analytics. Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=
